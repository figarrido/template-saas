{
  "name": "@template/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/database.types.ts",
    "./schema": "./src/drizzle/schema.ts"
  },
  "scripts": {
    "db:types": "supabase gen types typescript --local --schema public > src/types/database.types.ts",
    "db:types:check": "tsx scripts/types-drift.ts",
    "db:introspect": "drizzle-kit introspect && tsx scripts/post-introspect.ts",
    "db:introspect:check": "tsx scripts/introspect-drift.ts",
    "test:rls": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@template/config": "workspace:*",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
