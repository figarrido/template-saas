# Generated from packages/env/src/web.schema.ts
# Do not edit by hand. Run `pnpm env:example` to regenerate.

# Runtime mode. Sentry init is guarded by `production`.
# (optional) NODE_ENV=development

# Release tag surfaced in logs / Sentry / OTel resource attrs.
# (optional) RELEASE=

# Supabase project URL (server-only). Local: from `supabase status`.
SUPABASE_URL=http://127.0.0.1:54421

# Service-role key. Server/admin/workers only — NEVER ship to a client.
SUPABASE_SERVICE_ROLE_KEY=eyJ...replace-me

# Sentry DSN. Absent = no-op in any environment.
# (optional) SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# OTel collector endpoint. Absent = stdout / no-op.
# (optional) OTEL_EXPORTER_OTLP_ENDPOINT=

# Stripe API secret key (test in dev).
STRIPE_SECRET_KEY=sk_test_replace_me

# Stripe webhook signing secret. From `stripe listen` in dev.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Resend API key. Absent in dev — SmtpProvider routes to InBucket.
# (optional) RESEND_API_KEY=

# `smtp` in dev (InBucket), `resend` in prod.
# (optional) MAIL_PROVIDER=smtp

# InBucket host. Written by `pnpm setup` from `supabase status`.
# (optional) SMTP_HOST=127.0.0.1

# InBucket port. Written by `pnpm setup` from `supabase status`.
# (optional) SMTP_PORT=54425

# Standard Webhooks key for the Supabase send-email Auth hook (ADR-0005). Must match supabase/config.toml.
# (optional) SEND_EMAIL_HOOK_SECRET=v1,whsec_replace_me

# From: address for verification / recovery / email-change emails.
# (optional) AUTH_EMAIL_FROM=Auth <auth@template.test>

# Upstash Redis REST URL. Absent = rate-limit no-ops.
# (optional) UPSTASH_REDIS_REST_URL=

# Upstash Redis REST token.
# (optional) UPSTASH_REDIS_REST_TOKEN=

# PostHog server-side project key (for OpenFeature provider).
# (optional) POSTHOG_PROJECT_API_KEY=

# Supabase URL exposed to the browser.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54421

# Supabase publishable key exposed to the browser (replaces legacy anon key; RLS-bound).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace-me

# (optional) NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# (optional) NEXT_PUBLIC_POSTHOG_KEY=phc_replace_me

# (optional) NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Public origin used for OAuth callbacks, emails, etc.
NEXT_PUBLIC_SITE_URL=https://template.localhost
