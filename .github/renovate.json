{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard",
    ":maintainLockFilesWeekly"
  ],
  "schedule": ["before 6am on monday"],
  "timezone": "UTC",
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["before 6am on monday"]
  },
  "packageRules": [
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "matchPackageNames": [
        "next",
        "react",
        "react-dom",
        "@supabase/supabase-js",
        "supabase",
        "drizzle-orm",
        "drizzle-kit",
        "typescript",
        "turbo"
      ],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "runtime-major", "needs-review"]
    },
    {
      "groupName": "radix-ui",
      "matchPackagePatterns": ["^@radix-ui/"]
    },
    {
      "groupName": "opentelemetry",
      "matchPackagePatterns": ["^@opentelemetry/"]
    },
    {
      "groupName": "sentry",
      "matchPackagePatterns": ["^@sentry/"]
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  }
}
